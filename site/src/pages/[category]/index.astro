---
import Base from '../../layouts/Base.astro';
import { CATEGORIES, getSkillsByCategory } from '../../lib/skills';

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map(category => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const label = CATEGORIES[category!] ?? category;
const skills = getSkillsByCategory(category!);
---

<Base
  title={label}
  description={`Evidence-backed skills for engineering leaders: ${label}`}
>
  <div class="category-header">
    <div class="breadcrumb">
      <a href="/">All skills</a>
    </div>
    <h1>{label}</h1>
    <p style="color: var(--color-text-muted)">
      {skills.length} skill{skills.length !== 1 ? 's' : ''}
    </p>
  </div>

  <ul class="skill-tree__list">
    {skills.map(skill => (
      <li class="skill-tree__item">
        <a href={`/skills/${skill.slug}/`}>{skill.frontmatter.title}</a>
        <span class="skill-tree__sep"> — </span>
        <span class="skill-tree__desc">{skill.frontmatter['when-to-use']}</span>
      </li>
    ))}
  </ul>
</Base>
