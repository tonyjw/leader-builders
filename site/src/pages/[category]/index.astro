---
import Base from '../../layouts/Base.astro';
import SkillCard from '../../components/SkillCard.astro';
import { CATEGORIES, getSkillsByCategory } from '../../lib/skills';

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map(category => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const label = CATEGORIES[category!] ?? category;
const skills = getSkillsByCategory(category!);
---

<Base
  title={label}
  description={`Evidence-backed skills for engineering leaders: ${label}`}
>
  <div class="category-header">
    <div class="breadcrumb">
      <a href="/">All skills</a>
    </div>
    <h1>{label}</h1>
    <p style="color: var(--color-text-muted)">
      {skills.length} skill{skills.length !== 1 ? 's' : ''}
    </p>
  </div>

  <div class="card-grid">
    {skills.map(skill => <SkillCard skill={skill} showCategory={false} />)}
  </div>
</Base>
