---
import Base from '../layouts/Base.astro';
import { getAllSkills, CATEGORIES, CATEGORY_DESCRIPTIONS, truncate } from '../lib/skills';
import { createSearchIndex, serializeIndex } from '../lib/searchIndex';

const skills = getAllSkills();
const searchIndex = createSearchIndex(skills);
const serializedIndex = serializeIndex(searchIndex);

const grouped = Object.entries(CATEGORIES)
  .map(([key, label]) => ({
    key,
    label,
    description: CATEGORY_DESCRIPTIONS[key] ?? '',
    skills: skills.filter(s => s.frontmatter.category === key),
  }))
  .filter(g => g.skills.length > 0);

const spotlightSkills = skills.map(s => ({
  slug: s.slug,
  title: s.frontmatter.title,
  category: s.frontmatter.category,
  categoryLabel: CATEGORIES[s.frontmatter.category] ?? s.frontmatter.category,
  whenToUse: s.frontmatter['when-to-use'],
  promptPreview: truncate(s.sections.promptCode, 260),
  difficulty: s.frontmatter.difficulty,
}));
---

<Base
  title="Evidence-backed skills for engineering leaders"
  description="A free library of structured prompts for engineering managers and leaders. Every skill includes research-backed reasoning."
>
  <div class="lp-page">

    <!-- ── HERO ─────────────────────────────────────────── -->
    <section class="lp-hero">
      <div class="lp-hero__inner">
        <div class="lp-hero__badge">Free &amp; Open Source</div>
        <h1 class="lp-hero__heading">Leader Builders</h1>
        <p class="lp-hero__tagline">Evidence-backed skills for engineering leaders</p>
        <p class="lp-hero__desc">
          A free library of research-backed prompts and frameworks for engineering managers.
          Every skill includes the reasoning behind it — grounded in research and practitioner
          experience — so you understand not just what to do, but why.
        </p>
        <div class="lp-search">
          <svg class="lp-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input
            type="text"
            id="skill-search"
            class="lp-search__input"
            placeholder="Search — e.g. 'difficult conversation' or 'sprint planning'"
            aria-label="Search skills"
            autocomplete="off"
          />
        </div>
        <p class="lp-hero__meta">{skills.length} skills &nbsp;·&nbsp; {grouped.length} categories</p>
      </div>
    </section>

    <!-- ── SEARCH RESULTS (shown while query is active) ── -->
    <div id="search-panel" class="lp-search-panel is-hidden">
      <div class="lp-inner">
        <div class="skill-tree" id="skills-tree">
          {grouped.map(({ key, label, skills }) => (
            <div class="skill-tree__category" data-category={key}>
              <h2 class="skill-tree__heading">{label}</h2>
              <ul class="skill-tree__list">
                {skills.map(skill => (
                  <li class="skill-tree__item" data-slug={skill.slug}>
                    <a href={`/skills/${skill.slug}/`}>{skill.frontmatter.title}</a>
                    <span class="skill-tree__sep"> — </span>
                    <span class="skill-tree__desc">{skill.frontmatter['when-to-use']}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div id="no-results" class="no-results" style="display: none;">
          <p>No skills match your search. Try different keywords.</p>
        </div>
      </div>
    </div>

    <!-- ── MAIN LANDING CONTENT ──────────────────────────── -->
    <div id="lp-main">

      <!-- CATEGORIES GRID -->
      <section class="lp-categories">
        <div class="lp-inner">
          <div class="lp-section-header">
            <h2 class="lp-section-header__title">Browse by category</h2>
            <p class="lp-section-header__desc">Six areas covering the full scope of engineering leadership</p>
          </div>
          <div class="lp-categories__grid">
            {grouped.map(({ key, label, description, skills }) => (
              <a href={`/${key}/`} class="lp-category-card">
                <h3 class="lp-category-card__heading">{label}</h3>
                <p class="lp-category-card__desc">{description}</p>
                <div class="lp-category-card__footer">
                  <span class="lp-category-card__count">{skills.length} skill{skills.length !== 1 ? 's' : ''}</span>
                  <span class="lp-category-card__arrow">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- SKILL SPOTLIGHT -->
      <section class="lp-spotlight">
        <div class="lp-inner">
          <div class="lp-spotlight__header">
            <span class="lp-spotlight__label">Skill spotlight</span>
            <div class="lp-spotlight__dots" id="spotlight-dots"></div>
          </div>
          <div id="spotlight-content" class="lp-spotlight__content">
            <!-- Rendered by JS -->
          </div>
        </div>
      </section>

    </div><!-- /#lp-main -->

  </div><!-- /.lp-page -->
</Base>

<style is:global>
  body:has(.lp-page) .container {
    max-width: unset;
    padding: 0;
  }
</style>

<script define:vars={{ serializedIndex, spotlightSkills }}>
  window.searchIndex = serializedIndex;
  window.spotlightSkills = spotlightSkills;
</script>

<script src="/lunr.js" is:inline></script>

<script>
  /* ── Search ─────────────────────────────────────────── */
  window.addEventListener('load', () => {
    const searchInput  = document.getElementById('skill-search');
    const searchPanel  = document.getElementById('search-panel');
    const mainContent  = document.getElementById('lp-main');
    const noResults    = document.getElementById('no-results');
    const tree         = document.getElementById('skills-tree');
    if (!searchInput || !tree || !searchPanel || !mainContent) return;

    const index = lunr.Index.load(JSON.parse(window.searchIndex));

    function performSearch() {
      const query = searchInput.value.trim();

      if (query === '') {
        searchPanel.classList.add('is-hidden');
        mainContent.classList.remove('is-hidden');
        return;
      }

      searchPanel.classList.remove('is-hidden');
      mainContent.classList.add('is-hidden');

      const items = tree.querySelectorAll('.skill-tree__item');
      let totalVisible = 0;
      let matchedSlugs = new Set();
      try { matchedSlugs = new Set(index.search(query).map(r => r.ref)); } catch (e) {}

      items.forEach(item => {
        const visible = matchedSlugs.has(item.dataset.slug || '');
        item.classList.toggle('is-hidden', !visible);
        if (visible) totalVisible++;
      });

      tree.querySelectorAll('.skill-tree__category').forEach(cat => {
        const hasVisible = cat.querySelectorAll('.skill-tree__item:not(.is-hidden)').length > 0;
        cat.classList.toggle('is-hidden', !hasVisible);
      });

      if (noResults) noResults.style.display = totalVisible === 0 ? 'block' : 'none';
      tree.style.display = totalVisible === 0 ? 'none' : '';
    }

    searchInput.addEventListener('input', performSearch);
  });

  /* ── Spotlight ──────────────────────────────────────── */
  (function () {
    const skills = window.spotlightSkills;
    if (!skills || skills.length === 0) return;

    const contentEl = document.getElementById('spotlight-content');
    const dotsEl    = document.getElementById('spotlight-dots');
    if (!contentEl || !dotsEl) return;

    const INTERVAL = 15000;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let current = Math.floor(Math.random() * skills.length);
    let timer;

    function startTimer() {
      if (reducedMotion) return;
      timer = setInterval(advance, INTERVAL);
    }

    function stopTimer() {
      clearInterval(timer);
    }

    // Pause on hover or focus within the spotlight section
    const spotlightEl = contentEl.closest('.lp-spotlight');
    if (spotlightEl) {
      spotlightEl.addEventListener('pointerenter', stopTimer);
      spotlightEl.addEventListener('pointerleave', startTimer);
      spotlightEl.addEventListener('focusin', stopTimer);
      spotlightEl.addEventListener('focusout', startTimer);
    }

    skills.forEach((_, i) => {
      const btn = document.createElement('button');
      btn.className = 'lp-spotlight__dot';
      btn.setAttribute('aria-label', `Show skill ${i + 1}`);
      btn.dataset.idx = String(i);
      btn.addEventListener('click', () => {
        stopTimer();
        current = i;
        render(current);
        startTimer();
      });
      dotsEl.appendChild(btn);
    });

    function escHtml(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function render(idx) {
      const s = skills[idx];
      contentEl.innerHTML = `
        <div class="lp-spotlight__item">
          <div class="lp-spotlight__skill">
            <span class="lp-spotlight__category-badge">${escHtml(s.categoryLabel)}</span>
            <h3 class="lp-spotlight__title">${escHtml(s.title)}</h3>
            <p class="lp-spotlight__when">${escHtml(s.whenToUse)}</p>
            <a href="/skills/${s.slug}/" class="lp-spotlight__link">Read this skill <span aria-hidden="true">→</span></a>
          </div>
          <div class="lp-spotlight__prompt-wrap">
            <div class="lp-spotlight__prompt-label">Prompt preview</div>
            <pre class="lp-spotlight__prompt-pre">${escHtml(s.promptPreview)}&hellip;</pre>
          </div>
        </div>
      `;

      dotsEl.querySelectorAll('.lp-spotlight__dot').forEach((dot, i) => {
        dot.classList.toggle('is-active', i === idx);
      });
    }

    function advance() {
      current = (current + 1) % skills.length;
      render(current);
    }

    render(current);
    startTimer();
  })();
</script>
