---
import Base from '../layouts/Base.astro';
import SkillCard from '../components/SkillCard.astro';
import { getAllSkills } from '../lib/skills';
import { createSearchIndex, serializeIndex } from '../lib/searchIndex';

const skills = getAllSkills();
const searchIndex = createSearchIndex(skills);
const serializedIndex = serializeIndex(searchIndex);
---

<Base
  title="Evidence-backed skills for engineering leaders"
  description="A structured skill library for engineering managers and leaders. Every skill includes a prompt, evidence-backed reasoning, and failure modes."
>
  <section class="hero">
    <h1>eng.builders</h1>
    <p class="hero__tagline">Evidence-backed skills for engineering leaders</p>
    <p class="hero__desc">
      A library of structured prompts for engineering managers and leaders.
      Every skill comes with the reasoning behind it — grounded in research and
      practitioner experience — so you understand not just what to do, but why.
    </p>
    <p class="hero__link">
      <a href="https://github.com/tonyjw/leader-builders" target="_blank" rel="noopener">
        View on GitHub &rarr;
      </a>
    </p>
  </section>

  <div class="search-container">
    <input
      type="text"
      id="skill-search"
      class="search-input"
      placeholder="Describe your situation..."
      aria-label="Search skills"
    />
  </div>

  <div class="card-grid" id="skills-grid">
    {skills.map(skill => <SkillCard skill={skill} showCategory={true} />)}
  </div>

  <div id="no-results" class="no-results" style="display: none;">
    <p>No skills match your search. Try different keywords.</p>
  </div>
</Base>

<script define:vars={{ serializedIndex }}>
  // Embed the search index as a JavaScript variable
  window.searchIndex = serializedIndex;
</script>

<script src="/lunr.js" is:inline></script>

<script>
  // Initialize search after Lunr loads
  window.addEventListener('load', () => {
    // Get the serialized index from the global variable
    const serializedIndex = window.searchIndex;
    
    function initializeSearch(serializedIndex) {
      const searchInput = document.getElementById('skill-search');
      const cards = document.querySelectorAll('.skill-card');
      const noResultsMessage = document.getElementById('no-results');
      const skillsGrid = document.getElementById('skills-grid');

      if (!searchInput) return;

      // Deserialize the Lunr index
      const index = lunr.Index.load(JSON.parse(serializedIndex));

      function performSearch() {
        const query = searchInput.value.trim();
        let visibleCount = 0;
        let matchedSlugs = new Set();

        if (query === '') {
          // Show all cards if search is empty
          cards.forEach(card => {
            card.style.display = '';
            visibleCount++;
          });
        } else {
          // Search using Lunr
          try {
            const results = index.search(query);
            matchedSlugs = new Set(results.map(r => r.ref));
          } catch (e) {
            // If Lunr query fails (e.g., special characters), fall back to empty results
            matchedSlugs = new Set();
          }

          cards.forEach(card => {
            const slug = card.dataset.slug;
            if (matchedSlugs.has(slug || '')) {
              card.style.display = '';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });
        }

        // Show/hide no results message
        if (noResultsMessage && skillsGrid) {
          if (visibleCount === 0 && query !== '') {
            noResultsMessage.style.display = 'block';
            skillsGrid.style.display = 'none';
          } else {
            noResultsMessage.style.display = 'none';
            skillsGrid.style.display = 'grid';
          }
        }
      }

      searchInput.addEventListener('input', performSearch);
    }

    initializeSearch(serializedIndex);
  });
</script>
